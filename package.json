{
  "name": "kiro-steering-studio",
  "version": "0.1.0",
  "description": "Voice-powered steering file generator for Kiro using Amazon Nova Sonic",
  "private": false,
  "type": "commonjs",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.785.0",
    "@aws-sdk/credential-provider-node": "^3.785.0",
    "@aws-sdk/credential-providers": "^3.785.0",
    "@smithy/node-http-handler": "^4.0.4",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "socket.io": "^4.8.1",
    "uuid": "^11.1.0",
    "zod": "^3.23.8",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.9",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "prettier": "^3.4.2",
    "tsx": "^4.19.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.20.0"
  },
  "keywords": [
    "kiro",
    "steering",
    "voice",
    "amazon",
    "bedrock",
    "nova-sonic",
    "ai"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aws-samples/kiro-steering-studio"
  }
}
